# === 必須設定 ===

# GCPプロジェクトID（Vertex AI / Gemini API用）
GCP_PROJECT_ID=your-gcp-project-id

# === トークン設定 ===
# 形式: {"トークン文字列": "顧客名"}
# 複数のトークンはカンマ区切りで設定
# 例: {"abc123xyz": "株式会社A", "def456uvw": "B事務所"}
VALID_TOKENS={"your-token-here": "Customer Name"}

# === 任意設定 ===

# Gemini API モデル名（デフォルト: gemini-2.5-flash）
# GEMINI_MODEL=gemini-2.5-flash

# GCPロケーション（デフォルト: us-central1）
# GCP_LOCATION=us-central1

# デバッグモード（デフォルト: False）
# DEBUG=False

# ログレベル（デフォルト: INFO）
# LOG_LEVEL=INFO

# アップロード最大サイズ（MB、デフォルト: 10）
# MAX_UPLOAD_SIZE_MB=10

# Gemini APIタイムアウト（秒、デフォルト: 120）
# GEMINI_TIMEOUT_SECONDS=120

# Sentry DSN（エラーレポート用、任意）
# SENTRY_DSN=

# サーバーポート（デフォルト: 8080）
# PORT=8080
